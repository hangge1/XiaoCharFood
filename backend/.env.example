# Runtime
PORT=3001

# Storage
# json is useful for debugging; sqlite is recommended for single-node deployment validation.
STORAGE_BACKEND=sqlite
DATA_DIR=./data
SQLITE_PATH=./data/xiaocharfood.sqlite3

# WeChat Mini Program auth
WECHAT_APP_ID=replace_with_your_app_id
WECHAT_APP_SECRET=replace_with_your_app_secret

# Backend session
SESSION_SECRET=replace_with_a_long_random_secret
SESSION_TTL_SECONDS=2592000

# Local development only. Set to false in production.
ALLOW_DEV_AUTH=true

