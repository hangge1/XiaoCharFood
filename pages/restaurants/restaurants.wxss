.compact {
  margin: 0 0 18rpx;
}

.restaurant-hero {
  margin-bottom: 28rpx;
  padding-top: 12rpx;
}

.restaurant-hero .title {
  margin-top: 18rpx;
}

.mode-switch {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.mode-item {
  min-height: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 22rpx;
  color: #5D675B;
  background: #EEF3EA;
  font-weight: 650;
  font-size: 26rpx;
  box-shadow: inset 0 -4rpx 0 rgba(32, 37, 31, 0.04);
}

.mode-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.7);
  font-size: 30rpx;
}

.mode-item.active {
  color: #FFFFFF;
  background: #2F7D68;
}

.mode-item.active .mode-icon {
  background: rgba(255, 255, 255, 0.22);
}

.create-card {
  border-color: #A8D2C3;
  background: #FFFCF4;
}

.search-card {
  border-color: #C9E0D6;
  background: #F5FBF7;
}

.search-box {
  display: grid;
  grid-template-columns: 1fr 132rpx;
  gap: 12rpx;
  margin-top: 20rpx;
}

.search-input {
  min-height: 84rpx;
  padding: 20rpx;
  border: 1rpx solid #DDE4D7;
  border-radius: 999rpx;
  background: #FFFFFF;
  box-sizing: border-box;
  font-size: 28rpx;
}

.search-button {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #FFFFFF;
  background: #2F7D68;
  font-weight: 700;
}

.clear-search {
  margin-top: 12rpx;
  color: #87907F;
  font-size: 24rpx;
  text-align: right;
}

.search-dropdown {
  margin-top: 14rpx;
  padding: 12rpx;
  border: 1rpx solid #DDE4D7;
  border-radius: 22rpx;
  background: #FFFFFF;
  box-shadow: 0 16rpx 32rpx rgba(47, 72, 56, 0.08);
}

.search-result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 8rpx;
  border-bottom: 1rpx solid #EEF3EA;
}

.search-result:last-child {
  border-bottom: 0;
}

.search-empty,
.search-empty-block {
  padding: 24rpx;
  color: #5D675B;
  text-align: center;
}

.search-empty-block {
  margin-top: 18rpx;
  border-radius: 22rpx;
  background: #FFFFFF;
}

.map-card {
  border-color: #A8D2C3;
  background: #F5FBF7;
}

.gap {
  margin-top: 20rpx;
}

.gap-small {
  margin-top: 14rpx;
}

.restaurant-title {
  font-size: 34rpx;
  font-weight: 700;
}

.restaurant-title.small {
  font-size: 30rpx;
}

.visit-count {
  flex: 0 0 auto;
  color: #2F7D68;
  font-weight: 700;
}

.visit-box {
  margin: 18rpx 0;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #F7F8F3;
}

.location-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 16rpx;
  padding: 20rpx;
  border: 2rpx dashed rgba(47, 125, 104, 0.28);
  border-radius: 20rpx;
  background: #F5FBF7;
}

.location-title {
  font-size: 28rpx;
  font-weight: 650;
}

.location-action {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  background: #2F7D68;
  font-size: 24rpx;
  font-weight: 650;
}

.nearby-map {
  width: 100%;
  height: 460rpx;
  margin-top: 22rpx;
  border-radius: 22rpx;
  overflow: hidden;
}

.map-empty {
  margin-top: 16rpx;
}

.nearby-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #FFFFFF;
}
