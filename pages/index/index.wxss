.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding-top: 12rpx;
}

.hero .meta {
  margin-top: 18rpx;
}

.hero-face {
  width: 108rpx;
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #2F7D68;
  border-radius: 34rpx;
  background: #DDEFE8;
  color: #2F7D68;
  font-size: 30rpx;
  font-weight: 900;
  transform: rotate(6deg);
  box-shadow: 8rpx 10rpx 0 rgba(47, 125, 104, 0.18);
}

.nickname-card,
.today-card {
  border-color: #A8D2C3;
}

.note-card {
  background: #FFFCF4;
  border-color: #F2D7A7;
}

.review-card {
  background: #F5FBF7;
  border-color: #C9E0D6;
}

.compact {
  margin: 0;
}

.meal-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-top: 20rpx;
}

.meal-cell {
  min-height: 104rpx;
  padding: 16rpx 10rpx;
  border: 1rpx solid #DDE4D7;
  border-radius: 20rpx;
  background: #F7F8F3;
  text-align: center;
  box-sizing: border-box;
  transform: rotate(-1deg);
}

.meal-cell.active {
  border-color: #2F7D68;
  background: #DDEFE8;
  color: #2F7D68;
  font-weight: 650;
  transform: rotate(1deg) translateY(-4rpx);
}

.form-gap {
  margin-top: 20rpx;
}

.note-card .input {
  margin-top: 16rpx;
}

.feeling-input {
  background: #FFFDF8;
}

.tag-label {
  margin-top: 18rpx;
  color: #87907F;
  font-size: 24rpx;
}

.note-card .chip {
  min-height: 54rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.edit-badge {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #A75031;
  background: #F8E5DC;
  font-size: 24rpx;
  font-weight: 700;
}

.form-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 22rpx;
}

.form-actions.with-side {
  grid-template-columns: 1fr 156rpx;
}

.action-main,
.action-side {
  min-width: 0;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 20rpx 0;
}

.stats > view {
  padding: 18rpx 10rpx;
  border-radius: 22rpx;
  background: #FFFFFF;
  text-align: center;
}

.stat-num {
  color: #2F7D68;
  font-size: 38rpx;
  font-weight: 700;
}

.tip {
  margin-top: 12rpx;
  color: #5D675B;
  font-size: 26rpx;
}

.meal-title {
  font-size: 32rpx;
  font-weight: 650;
}

.note {
  margin: 14rpx 0;
}

.meal-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 0 0 auto;
}

.icon-action {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #EEF3EA;
  color: #2F7D68;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1;
}

.icon-action.edit {
  transform: rotate(-5deg);
}

.icon-action.danger {
  background: #F8E5DC;
  color: #A75031;
  transform: rotate(5deg);
}
