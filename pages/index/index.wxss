.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 28rpx;
  padding-top: 12rpx;
}

.hero .meta {
  margin-top: 18rpx;
}

.hero-face {
  width: 108rpx;
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #2F7D68;
  border-radius: 34rpx;
  background: #DDEFE8;
  color: #2F7D68;
  font-size: 30rpx;
  font-weight: 900;
  transform: rotate(6deg);
  box-shadow: 8rpx 10rpx 0 rgba(47, 125, 104, 0.18);
}

.nickname-card,
.today-card {
  border-color: #A8D2C3;
}

.note-card {
  background: #FFFCF4;
  border-color: #F2D7A7;
}

.review-card {
  background: #F5FBF7;
  border-color: #C9E0D6;
}

.compact {
  margin: 0;
}

.meal-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.meal-cell {
  position: relative;
  min-height: 172rpx;
  padding: 14rpx 10rpx 16rpx;
  border: 1rpx solid #DDE4D7;
  border-radius: 24rpx;
  background: #F7F8F3;
  overflow: hidden;
  text-align: center;
  box-sizing: border-box;
  transform: rotate(-1deg);
  transition: transform 160ms ease, box-shadow 160ms ease;
}

.meal-cell::after {
  content: "";
  position: absolute;
  right: 12rpx;
  top: 12rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: -22rpx 16rpx 0 rgba(255, 255, 255, 0.48);
}

.meal-cell.morning {
  background: #FFF2CD;
  border-color: #F0C879;
}

.meal-cell.noon {
  background: #E7F2DB;
  border-color: #BAD59B;
  transform: rotate(1deg);
}

.meal-cell.night {
  background: #E5EFF8;
  border-color: #AFCBE2;
  transform: rotate(-2deg);
}

.meal-cell.snack {
  background: #FCE5E4;
  border-color: #E8B7B4;
  transform: rotate(2deg);
}

.meal-art {
  position: relative;
  width: 104rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10rpx;
}

.meal-glow {
  position: absolute;
  width: 82rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 10rpx 0 rgba(32, 37, 31, 0.06);
}

.meal-icon {
  position: relative;
  z-index: 1;
  font-size: 58rpx;
  line-height: 1;
  transform: rotate(-3deg);
}

.meal-name {
  position: relative;
  z-index: 1;
  color: #344033;
  font-family: "Comic Sans MS", "PingFang SC", "Microsoft YaHei UI", sans-serif;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 36rpx;
}

.meal-cell.active {
  border-color: #2F7D68;
  color: #2F7D68;
  box-shadow: 0 12rpx 0 rgba(47, 125, 104, 0.16);
  transform: rotate(1deg) translateY(-4rpx);
}

.meal-cell.active .meal-glow {
  background: #FFFFFF;
}

.meal-cell.active .meal-name {
  color: #2F7D68;
}

.form-gap {
  margin-top: 20rpx;
}

.note-card .input {
  margin-top: 16rpx;
}

.feeling-input {
  background: #FFFDF8;
}

.companion-field {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
  padding: 0 18rpx;
  border: 1rpx solid #DDE4D7;
  border-radius: 24rpx;
  background: #F5FBF7;
  box-sizing: border-box;
}

.companion-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #DDEFE8;
  font-size: 28rpx;
}

.companion-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  font-size: 28rpx;
}

.companion-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.companion-chip {
  min-height: 54rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #2F7D68;
  background: #DDEFE8;
  font-size: 24rpx;
  box-shadow: inset 0 -4rpx 0 rgba(32, 37, 31, 0.04);
}

.companion-chip.active {
  color: #FFFFFF;
  background: #2F7D68;
}

.tag-label {
  margin-top: 18rpx;
  color: #87907F;
  font-size: 24rpx;
}

.note-card .chip,
.note-chip {
  min-height: 54rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.note-chip {
  gap: 6rpx;
  box-shadow: inset 0 -4rpx 0 rgba(32, 37, 31, 0.04);
}

.chip-dot {
  width: 28rpx;
  height: 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1;
}

.edit-badge {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #A75031;
  background: #F8E5DC;
  font-size: 24rpx;
  font-weight: 700;
}

.form-actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 22rpx;
}

.form-actions.with-side {
  grid-template-columns: 1fr 156rpx;
}

.action-main,
.action-side {
  min-width: 0;
}

.stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: 20rpx 0;
}

.stats > view {
  padding: 18rpx 10rpx;
  border-radius: 22rpx;
  background: #FFFFFF;
  text-align: center;
}

.stat-num {
  color: #2F7D68;
  font-size: 38rpx;
  font-weight: 700;
}

.tip {
  margin-top: 12rpx;
  color: #5D675B;
  font-size: 26rpx;
}

.meal-title {
  font-size: 32rpx;
  font-weight: 650;
}

.note {
  margin: 14rpx 0;
}

.companion-meta {
  margin-top: 8rpx;
  color: #2F7D68;
  font-size: 24rpx;
  font-weight: 650;
}

.meal-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 0 0 auto;
}

.icon-action {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: #EEF3EA;
  color: #2F7D68;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1;
}

.icon-action.edit {
  transform: rotate(-5deg);
}

.icon-action.danger {
  background: #F8E5DC;
  color: #A75031;
  transform: rotate(5deg);
}
